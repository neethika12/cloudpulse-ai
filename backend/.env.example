DATABASE_URL=postgresql+psycopg2://cloudpulse:cloudpulse@db:5432/cloudpulse
ENVIRONMENT=development

# Fully local AI - no API key needed. Both models download from Hugging Face
# on first use and run inside the backend container.
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
CHAT_MODEL=google/flan-t5-base

# Optional - leave blank to skip Slack alerts. See README for setup steps.
SLACK_WEBHOOK_URL=

# Auth - generate a real random secret for anything beyond local dev, e.g.:
# python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=dev-secret-change-me
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# Encrypts AWS secret access keys at rest. Generate a real one for anything beyond
# local dev: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
APP_ENCRYPTION_KEY=HicjRZLuUYNG8mY1YeYDN5WbfeESSC5ovmp793lVLrU=
