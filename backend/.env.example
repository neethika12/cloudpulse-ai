DATABASE_URL=postgresql+psycopg2://cloudpulse:cloudpulse@db:5432/cloudpulse
ENVIRONMENT=development

# Fully local AI - no API key needed. Both models download from Hugging Face
# on first use and run inside the backend container.
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
CHAT_MODEL=google/flan-t5-base

# Optional - leave blank to skip Slack alerts. See README for setup steps.
SLACK_WEBHOOK_URL=
